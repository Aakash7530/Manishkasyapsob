<?php

require_once __DIR__ . '/../utils/basic.inc';

// Vector [127,7] with padding 0
$vector = array (
  0 => 0,
  1 => 1,
  2 => 1,
  3 => 1,
  4 => 1,
  5 => 1,
  6 => 1,
  7 => 1,
  8 => 0,
  9 => 0,
  10 => 0,
  11 => 0,
  12 => 0,
  13 => 1,
  14 => 1,
  15 => 1,
);

$binary = MongoDB\BSON\Binary::fromVector($vector, \MongoDB\BSON\VectorType::PackedBit);
echo bin2hex((string) MongoDB\BSON\Document::fromPHP(['vector' => $binary])), "\n";

$bson = MongoDB\BSON\Document::fromBSON(hex2bin('1600000005766563746F7200040000000910007F0700'));
var_dump($binary == $bson['vector']);

?>
