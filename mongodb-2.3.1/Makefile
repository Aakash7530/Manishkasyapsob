$(phplibdir)/mongodb.la: ./mongodb.la
	$(LIBTOOL) --tag=CC --mode=install cp ./mongodb.la $(phplibdir)

./mongodb.la: $(shared_objects_mongodb) $(MONGODB_SHARED_DEPENDENCIES)
	$(LIBTOOL) --tag=CC --mode=link $(CC) -shared $(COMMON_FLAGS) $(CFLAGS_CLEAN) $(EXTRA_CFLAGS) $(LDFLAGS)  -o $@ -export-dynamic -avoid-version -prefer-pic -module -rpath $(phplibdir) $(EXTRA_LDFLAGS) $(shared_objects_mongodb) $(MONGODB_SHARED_LIBADD)

